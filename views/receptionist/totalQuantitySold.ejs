<!DOCTYPE html>
<html>

<head>
     <meta charset="UTF-8">
     <meta http-equiv="X-UA-Compatible" content="IE=edge">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>Total Quantity Sold</title>
     <link rel="stylesheet" href="/stylesheets/style.css">
     <link rel="stylesheet" href="/stylesheets/adminStyle.css">
     <link rel="stylesheet" href="/stylesheets/receptionistStyle.css">
     <link rel="stylesheet" href="/stylesheets/productStyle.css">
</head>

<body>
     <%- include('../header', { user: user }) %>

          <div class="admin-dashboard">
               <div class="header-section">
                    <h1 class="dashboard-title">Total Quantity Sold by Product</h1>
               </div>

               <% if (products && products.length> 0) { %>
                    <table class="products-table">
                         <thead>
                              <tr>
                                   <th>Sr. No.</th>
                                   <th>Name</th>
                                   <th>Brand</th>
                                   <th>Total Quantity Sold</th>
                              </tr>
                         </thead>
                         <tbody>
                              <% products.forEach((p, index)=> { %>
                                   <tr>
                                        <td>
                                             <%= index + 1 %>
                                        </td>
                                        <td>
                                             <%= p.name ? p.name.charAt(0).toUpperCase() + p.name.slice(1) : '' %>
                                        </td>
                                        <td>
                                             <%= p.brand ? p.brand.toUpperCase() : '' %>
                                        </td>
                                        <td>
                                             <%= p.total_quantity_sold %>
                                        </td>
                                   </tr>
                                   <% }); %>
                         </tbody>
                    </table>
                    <% } else { %>
                         <p>No products sold yet.</p>
                         <% } %>
          </div>
</body>

</html>
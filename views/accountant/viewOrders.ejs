<!DOCTYPE html>
<html>

<head>
     <meta charset="UTF-8">
     <meta http-equiv="X-UA-Compatible" content="IE=edge">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
     <title>View Orders - Accountant</title>
     <link rel="stylesheet" href="/stylesheets/style.css">
     <link rel="stylesheet" href="/stylesheets/accountantStyle.css">
</head>

<body>
     <%- include('../header', { user: user }) %>

          <div class="accountant-container">
               <div class="orders-header">
                    <h1 class="page-title">All Orders</h1>
                    <div class="orders-info">
                         <span class="info-badge">
                              <%= orders.length %> Total Orders
                         </span>
                    </div>
               </div>

               <% if (orders && orders.length> 0) { %>
                    <div class="orders-table-wrapper">
                         <table class="orders-table">
                              <thead>
                                   <tr>
                                        <th>Order Item ID</th>
                                        <th>Customer Name</th>
                                        <th>Email</th>
                                        <th>Order Date</th>
                                        <th>Items</th>
                                        <th>Total Amount</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                   </tr>
                              </thead>
                              <tbody>
                                   <% orders.forEach((order)=> { %>
                                        <tr class="order-row <%= order.order_status %>">
                                             <td><span class="order-id">
                                                       <%= order.order_id %>
                                                  </span></td>
                                             <td>
                                                  <%= order.user_name %>
                                             </td>
                                             <td>
                                                  <%= order.email %>
                                             </td>
                                             <td>
                                                  <%= new Date(order.order_date).toLocaleDateString() %>
                                             </td>
                                             <td>
                                                  <span class="items-count">
                                                       <%= order.items_count %> items
                                                  </span>
                                             </td>
                                             <td class="amount">
                                                  ₹<%= parseFloat(order.total_amount) %>
                                             </td>
                                             <td>
                                                  <span class="status-badge <%= order.order_status %>">
                                                       <%= order.order_status.charAt(0).toUpperCase() +
                                                            order.order_status.slice(1) %>
                                                  </span>
                                             </td>
                                             <td>
                                                  <form action="/accountant/updateOrderStatus" method="POST"
                                                       class="status-form">
                                                       <input type="hidden" name="order_id"
                                                            value="<%= order.order_id %>">
                                                       <select name="order_status" class="status-select">
                                                            <option value="pending" <%=order.order_status==='pending'
                                                                 ? 'selected' : '' %>>Pending</option>
                                                            <option value="completed"
                                                                 <%=order.order_status==='completed' ? 'selected' : ''
                                                                 %>>Completed</option>
                                                            <option value="cancelled"
                                                                 <%=order.order_status==='cancelled' ? 'selected' : ''
                                                                 %>>Cancelled</option>
                                                            <option value="returned" <%=order.order_status==='returned'
                                                                 ? 'selected' : '' %>>Returned</option>
                                                       </select>
                                                       <button type="submit" class="update-btn">Update</button>
                                                  </form>
                                             </td>
                                        </tr>
                                        <% }); %>
                              </tbody>
                         </table>
                    </div>
                    <% } else { %>
                         <div class="no-orders-container">
                              <div class="no-orders-icon">📋</div>
                              <p class="no-orders-text">No orders found</p>
                              <p class="no-orders-subtitle">There are no orders to display at the moment</p>
                         </div>
                         <% } %>
          </div>

</body>

</html>